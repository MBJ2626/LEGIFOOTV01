{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd LEGIFOOT01-main && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd LEGIFOOT01-main && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100
  }
}
